generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma_v2"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  VIEWER
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @unique @db.VarChar(80)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash")
  role         UserRole @default(VIEWER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sitesCreated    Site[]          @relation("SitesCreatedBy")
  drillingCreated DrillingEntry[] @relation("DrillingEntriesCreatedBy")
  opexCreated     OpexEntry[]     @relation("OpexEntriesCreatedBy")
  dceCreated      DceEntry[]      @relation("DceEntriesCreatedBy")
  advanceCreated  AdvanceEntry[]  @relation("AdvanceEntriesCreatedBy")
  auditLogs       AuditLog[]
  refreshSessions RefreshSession[]

  @@index([role], map: "idx_users_role")
  @@map("users")
}

model RefreshSession {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  tokenHash    String    @map("token_hash") @db.VarChar(255)
  issuedAt     DateTime  @default(now()) @map("issued_at")
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  replacedById String?   @map("replaced_by_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_refresh_sessions_user_id")
  @@index([expiresAt], map: "idx_refresh_sessions_expires_at")
  @@map("refresh_sessions")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  method     String   @db.VarChar(10)
  route      String   @db.VarChar(255)
  statusCode Int      @map("status_code")
  success    Boolean
  metadata   String   @default("") @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId], map: "idx_audit_logs_user_id")
  @@index([createdAt], map: "idx_audit_logs_created_at")
  @@map("audit_logs")
}

model Site {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(150)
  createdById String   @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy      User            @relation("SitesCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  drillingEntries DrillingEntry[]
  opexEntries     OpexEntry[]
  dceEntries      DceEntry[]
  advanceEntries  AdvanceEntry[]

  @@unique([name], map: "uq_sites_name")
  @@index([createdById], map: "idx_sites_created_by")
  @@map("sites")
}

model DrillingEntry {
  id             String   @id @default(uuid()) @db.Uuid
  siteId         String   @map("site_id") @db.Uuid
  date           DateTime @db.Date
  meters         Decimal  @db.Decimal(12, 2)
  boreholeNumber String?  @map("borehole_number") @db.VarChar(80)
  createdById    String   @map("created_by_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  site      Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdBy User @relation("DrillingEntriesCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([siteId, date], map: "idx_drilling_entries_site_date")
  @@index([createdById], map: "idx_drilling_entries_created_by")
  @@map("drilling_entries")
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(120)
  sortOrder Int?     @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  expenseHeads ExpenseHead[]
  opexEntries  OpexEntry[]

  @@map("categories")
}

model ExpenseHead {
  id         String   @id @default(uuid()) @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  name       String   @db.VarChar(150)
  sortOrder  Int?     @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  opexEntries OpexEntry[]

  @@unique([categoryId, name], map: "uq_expense_heads_category_name")
  @@index([categoryId], map: "idx_expense_heads_category_id")
  @@map("expense_heads")
}

model OpexEntry {
  id            String   @id @default(uuid()) @db.Uuid
  siteId        String   @map("site_id") @db.Uuid
  categoryId    String   @map("category_id") @db.Uuid
  expenseHeadId String   @map("expense_head_id") @db.Uuid
  amount        Decimal  @db.Decimal(14, 2)
  date          DateTime @db.Date
  remarks       String   @default("") @db.Text
  createdById   String   @map("created_by_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  site       Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  category   Category   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  expenseHead ExpenseHead @relation(fields: [expenseHeadId], references: [id], onDelete: Restrict)
  createdBy  User       @relation("OpexEntriesCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([siteId, date], map: "idx_opex_entries_site_date")
  @@index([categoryId], map: "idx_opex_entries_category_id")
  @@index([expenseHeadId], map: "idx_opex_entries_expense_head_id")
  @@map("opex_entries")
}

enum DceStatus {
  ACTIVE
  PAUSED
  STOPPED
}

model DceEntry {
  id              String    @id @default(uuid()) @db.Uuid
  siteId          String    @map("site_id") @db.Uuid
  costHead        String    @map("cost_head") @db.VarChar(200)
  perDayCost      Decimal   @map("per_day_cost") @db.Decimal(14, 2)
  startDate       DateTime  @map("start_date") @db.Date
  status          DceStatus @default(ACTIVE)
  remarks         String    @default("") @db.Text
  pausedAt        DateTime? @map("paused_at") @db.Date
  stoppedAt       DateTime? @map("stopped_at") @db.Date
  totalPausedDays Int       @default(0) @map("total_paused_days")
  createdById     String    @map("created_by_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  site      Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdBy User @relation("DceEntriesCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([siteId, startDate], map: "idx_dce_entries_site_start_date")
  @@index([status], map: "idx_dce_entries_status")
  @@map("dce_entries")
}

model AdvanceEntry {
  id          String   @id @default(uuid()) @db.Uuid
  siteId      String   @map("site_id") @db.Uuid
  date        DateTime @db.Date
  amount      Decimal  @db.Decimal(14, 2)
  remarks     String   @default("") @db.Text
  createdById String   @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  site      Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdBy User @relation("AdvanceEntriesCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([siteId, date], map: "idx_advance_entries_site_date")
  @@map("advance_entries")
}
