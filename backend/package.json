{
  "name": "exploration-management-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit -p tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "seed:opex-taxonomy": "tsx src/scripts/seedOpexTaxonomy.ts",
    "cleanup:legacy-opex-taxonomy": "tsx src/scripts/cleanupLegacyOpexTaxonomy.ts",
    "test": "tsx --test src/**/*.test.ts",
    "predeploy:check": "npm run lint && npm run test"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "argon2": "^0.40.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.15.3",
    "prisma": "^6.8.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
